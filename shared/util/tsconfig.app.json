{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2020", "DOM"],
        "skipLibCheck": true,
        "allowImportingTsExtensions": false,
        "strict": true,

        /* Reference */
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "rootDir": "src",
        "noEmit": false,
        "emitDeclarationOnly": true
    },
    "include": ["src"]
}
